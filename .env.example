# -----------------------------------------------------------------------
# .env.example — Template for your API keys
# -----------------------------------------------------------------------
# Copy this file and rename the copy to ".env" (without the word "example").
# Then replace each placeholder value with your real API key.
#
# IMPORTANT: Never commit your real .env file to GitHub.
# The .gitignore file in this repository already excludes it.
# -----------------------------------------------------------------------

# Your OpenAI API key — used by Scripts 2, 3, 6, and 8 (when PROVIDER = "openai")
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Your Anthropic API key — used by Scripts 7 and 8 (when PROVIDER = "claude")
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Azure AI credentials — used by Script 4 only (legacy example)
# Get these from your Azure AI Project portal
AZURE_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project
AZURE_AGENT_ID=asst_your-agent-id-here
AZURE_CLIENT_ID=your-azure-client-id
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_SECRET=your-azure-client-secret
